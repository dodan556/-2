rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /site_config/{document} {
      allow read, write: if true;
    }
    match /skills/{document} {
      allow read, write: if true;
    }
    match /portfolio_items/{document} {
      allow read, write: if true;
    }
    match /contact_messages/{document} {
      allow read, write: if true;
    }
  }
}
